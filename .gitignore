# ============================================
# TeachAny Opensource .gitignore
# ============================================

# === OS ===
.DS_Store
Thumbs.db

# === IDE ===
.vscode/
.idea/
*.swp
*.swo

# === Node ===
node_modules/
package-lock.json

# === Build Artifacts ===
dist/
build/
*.min.js
*.min.css
output/

# === Admin skill (local only) ===
admin-skillhub-package/

# === Archive (too large for Git) ===
archive/

# === Python 环境 ===
venv/
.venv/
__pycache__/
*.pyc
*.pyo

# === Registry 备份文件 ===
registry-backup-*.json
registry.json.backup.*
courseware-registry-backup-*.json
registry_backup_*.json
registry_fixed.json

# === 知识树备份（清污脚本产生） ===
data/trees/_backup_*/

# === 通用备份文件 ===
*.backup
*.backup-*
*.broken_backup

# === 临时验证脚本（仅根目录的，不影响 skill/scripts/）===
quick-verify.py
verify-*.py
verify_*.py
/check-*.sh
/verify-*.sh

# === 诊断/报告 JSON ===
quality-check-report.json
*-report.json
*_report.json

# === 测试/调试 HTML ===
test-*.html
test.html
debug.html
verify-*.html
清除缓存.html
知识图谱链接诊断.html
诊断*.html

# === 一次性报告 .md（保留核心文档） ===
ARCHITECTURE_REFACTOR_PLAN.md
ARCHIVE_README.md
COMMUNITY_INTEGRATION_VERIFICATION_REPORT.md
COMPOUND_VOWEL_RESTORATION_REPORT.md
